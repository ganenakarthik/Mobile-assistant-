<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 1. Ambient Background Radial Glow -->
    <path
        android:pathData="M54,54m-44,0a44,44 0,1 1,88 0a44,44 0,1 1,-88 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="44">
                <item android:offset="0" android:color="#4D12005C" /> <!-- Deep glow base violet -->
                <item android:offset="0.6" android:color="#2600255C" /> <!-- Deep glow base blue -->
                <item android:offset="1" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 2. Volumetric Subtle Background Particle Wave -->
    <path
        android:strokeWidth="1.5"
        android:strokeAlpha="0.4"
        android:pathData="M 18,54 Q 36,40 54,54 T 90,54">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="18"
                android:startY="54"
                android:endX="90"
                android:endY="54">
                <item android:offset="0" android:color="#00E5FF" />
                <item android:offset="1" android:color="#9D4EDD" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 3. Outer Glass Circle of the Orb -->
    <path
        android:pathData="M54,54m-31,0a31,31 0,1 1,62 0a31,31 0,1 1,-62 0"
        android:strokeWidth="3.2"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="23"
                android:startY="54"
                android:endX="85"
                android:endY="54">
                <item android:offset="0" android:color="#00E5FF" /> <!-- Cyan -->
                <item android:offset="0.5" android:color="#7B2CBF" /> <!-- Mid purple -->
                <item android:offset="1" android:color="#E0AAFF" /> <!-- Light Violet -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Thin glowing inner aura ring -->
    <path
        android:pathData="M54,54m-27,0a27,27 0,1 1,54 0a27,27 0,1 1,-54 0"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.7">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="27"
                android:startY="54"
                android:endX="81"
                android:endY="54">
                <item android:offset="0" android:color="#00E5FF" />
                <item android:offset="1" android:color="#9D4EDD" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 4. Glass specular highlight arc near top left -->
    <path
        android:fillColor="#1CFFFFFF"
        android:pathData="M 32,38 A 26,26 0 0,1 70,28 A 28,28 0 0,0 32,38 Z" />

    <!-- 5. Core Futuristic "N" Symbol -->
    <path
        android:strokeWidth="6.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M 44,66 L 44,42 L 64,66 L 64,42">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="44"
                android:startY="42"
                android:endX="64"
                android:endY="66">
                <item android:offset="0" android:color="#00E5FF" /> <!-- Electric Cyan -->
                <item android:offset="0.5" android:color="#9D4EDD" /> <!-- Mid Neon Purple -->
                <item android:offset="1" android:color="#FFFFFFFF" /> <!-- White Hot Core -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- 6. Specular Glow Dots for alignment -->
    <path
        android:fillColor="#8000E5FF"
        android:pathData="M 54,34 A 2,2 0 1,1 54,30 A 2,2 0 1,1 54,34 Z" />

</vector>
